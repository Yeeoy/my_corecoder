{
  "servers": {
    "exa": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.exa.ai/mcp"],
      "env": {},
      "auth_key": "EXA_API_KEY"
    },
     "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    }
  },
  "permissions": {
    "allow": [
      "mcp__exa__web_search_exa",
      "mcp__exa__web_fetch_exa",
      "mcp__fetch__fetch"
    ],
    "confirm": [],
    "deny": []
  }
}